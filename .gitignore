# 敏感配置文件（包含API密钥）⭐ 重要
.env
config/secrets.json
*_secret.json

# AI 缓存备份文件（自动生成，不需要版本控制）
config/ai_cache_backup/

# Python 字节码
__pycache__/
*.py[cod]
*$py.class
*.so

# 测试和临时文件
.pytest_cache/
.coverage
*.log

# IDE 配置
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes

